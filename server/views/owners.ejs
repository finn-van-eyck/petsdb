<header>
  <nav class="navbar navbar-expand-lg bg-body-tertiary mb-4">
    <div class="container-fluid">
      <a class="navbar-brand" href="/">PetDB</a>
      <button
        class="navbar-toggler"
        type="button"
        data-bs-toggle="collapse"
        data-bs-target="#navbarNav"
        aria-controls="navbarNav"
        aria-expanded="false"
        aria-label="Toggle navigation"
      >
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav">
          <li class="nav-item">
            <a class="nav-link" href="/">Owners</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/">Pets</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>
</header>
<div class="container">
  <h1>Owners manager</h1>
  <div class="row">
    <div class="col">
      <form action="/" method="post" class="form form-inline">
        <div class="row">
          <div class="col">
            <div class="form-floating mb-3">
              <input
                type="text"
                id="search"
                name="search"
                class="form-control"
              />
              <label for="search" class="form-label">Search</label>
            </div>
          </div>
          <div class="col">
            <button type="submit" class="btn btn-outline-primary">
              Search
            </button>
          </div>
        </div>
      </form>
    </div>
    <div class="col text-end">
      <a href="/edit_owner" class="btn btn-success">Create Owner</a>
    </div>
  </div>

  <table class="table table-striped">
    <thead>
      <tr>
        <th scope="col">#</th>
        <th scope="col">First Name</th>
        <th scope="col">Last Name</th>
        <th scope="col">City</th>
        <th scope="col">Country</th>
      </tr>
    </thead>
    <tbody>
      <% Pets.forEach((pet) => { %>
      <tr>
        <th scope="row"><%=pet.id%></th>
        <td><%=pet.firstname%></td>
        <td><%=pet.lastname%></td>
        <td><%=pet.city%></td>
        <td><%=pet.country%></td>
        <td>
          <a href="/edit_owner/<%=pet.id%>" class="btn btn-outline-primary">Edit</a>
          <a
            href="/owners/delete/1"
            onclick="return confirm('Are you sure?');"
            class="btn btn-outline-danger"
            >Delete</a
          >
        </td>
      </tr>
    <% }) %>
      
    </tbody>
  </table>

  <nav aria-label="Page navigation example">
    <ul class="pagination">
      <li class="page-item"><a class="page-link" href="#">1</a></li>
      <li class="page-item"><a class="page-link" href="#">2</a></li>
      <li class="page-item"><a class="page-link" href="#">3</a></li>
    </ul>
  </nav>
</div>
<script
  src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
  integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
  crossorigin="anonymous"
></script>
